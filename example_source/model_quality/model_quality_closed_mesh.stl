solid closed_tetrahedron
  facet normal 0 0 -1
    outer loop
      vertex 0.000 0.000 0.000
      vertex 0.000 1.000 0.000
      vertex 1.000 0.000 0.000
    endloop
  endfacet
  facet normal 0 -1 0
    outer loop
      vertex 0.000 0.000 0.000
      vertex 1.000 0.000 0.000
      vertex 0.000 0.000 1.000
    endloop
  endfacet
  facet normal 1 1 1
    outer loop
      vertex 1.000 0.000 0.000
      vertex 0.000 1.000 0.000
      vertex 0.000 0.000 1.000
    endloop
  endfacet
  facet normal -1 0 0
    outer loop
      vertex 0.000 1.000 0.000
      vertex 0.000 0.000 0.000
      vertex 0.000 0.000 1.000
    endloop
  endfacet
endsolid closed_tetrahedron
