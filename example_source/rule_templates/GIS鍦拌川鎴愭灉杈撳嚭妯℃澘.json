{
  "name": "GIS地质成果输出模板",
  "version": "2.0.0",
  "schema_version": "2.0",
  "project_type": "通用工程",
  "data_source": "通用数据",
  "input_formats": [
    "CSV",
    "GeoJSON",
    "SHP",
    "GPKG",
    "TIFF",
    "GeoTIFF"
  ],
  "description": "用于向 ArcGIS、QGIS 等 GIS 平台输出点、线、面、栅格及属性成果。",
  "author": "系统预置",
  "created_at": "2026-07-11T00:00:00",
  "updated_at": "2026-07-11T00:00:00",
  "tags": [
    "GIS",
    "GeoJSON",
    "GPKG",
    "ArcGIS",
    "QGIS"
  ],
  "enabled": true,
