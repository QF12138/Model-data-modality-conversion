import pandas as pd
import json
from datetime import datetime


# ======================================================
# 岩性结构化
# ======================================================
def build_lithology(df):
    lithology = []

    for _, row in df.iterrows():
        lithology.append({
            "top": float(row["Top"]),
            "bottom": float(row["Bottom"]),
            "name": row["Lithology"]
        })

    return lithology


# ======================================================
# 地下水结构化
# ======================================================
def build_groundwater(record):

    if record is None:
        return {}

    return {
        "water_level": float(record["water_level"]),
        "type": record["type"],
        "flow_direction": record["flow_direction"],
        "remark": record["remark"]
    }


# ======================================================
# 工程指标结构化
# ======================================================
def build_engineering(record):

    if record is None:
        return {}

    return {
        "UCS": float(record["UCS"]),
        "RQD": float(record["RQD"]),
        "permeability": float(record["permeability"])
    }


# ======================================================
# 建立统一Schema
# ======================================================
def build_schema(borehole, lithology, groundwater, engineering):

    return {

        "BH_ID": borehole["BH_ID"],

        "location": {
            "x": float(borehole["X"]),
            "y": float(borehole["Y"]),
            "z": float(borehole["Z"])
        },

        "lithology": lithology,

        "groundwater": groundwater,

        "engineering": engineering,

        "created": datetime.now().isoformat()

    }


# ======================================================
# 属性关联
# ======================================================
def merge_attribute(boreholes,
                    lithology_df,
                    groundwater_df,
                    engineering_df):

    result = []

    for _, bh in boreholes.iterrows():

        bhid = bh["BH_ID"]

        # -----------------------
        # 岩性
        # -----------------------
        lith_df = lithology_df[
            lithology_df["BH_ID"] == bhid
        ]

        lithology = build_lithology(lith_df)

        # -----------------------
        # 地下水
        # -----------------------
        gw_df = groundwater_df[
            groundwater_df["BH_ID"] == bhid
        ]

        groundwater = {}

        if not gw_df.empty:
            groundwater = build_groundwater(
                gw_df.iloc[0].to_dict()
            )

        # -----------------------
        # 工程指标
        # -----------------------
        eng_df = engineering_df[
            engineering_df["BH_ID"] == bhid
        ]

        engineering = {}

        if not eng_df.empty:
            engineering = build_engineering(
                eng_df.iloc[0].to_dict()
            )

        # -----------------------
        # 建立Schema
        # -----------------------
        result.append(
            build_schema(
                bh,
                lithology,
                groundwater,
                engineering
            )
        )

    return result


# ======================================================
# 导出JSON
# ======================================================
def export_json(data, filename):

    with open(filename, "w", encoding="utf-8") as f:
        json.dump(
            data,
            f,
            ensure_ascii=False,
            indent=4
        )

    print(f"\nJSON导出成功：{filename}")


